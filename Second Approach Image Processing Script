def split_by_segmented_maxima(combined_mask, original_img, prominence=2):
    """
    Split aggregated regions using h-maxima (segmented maxima with fixed prominence).
    prominence: how much darker a centre must be than its surroundings to count as separate.
    """
    # h-maxima on inverted image — finds dark centres separated by at least 'prominence' grey levels
    inverted = 255 - original_img.astype(np.uint8)
    maxima_mask = extrema.h_maxima(inverted, h=prominence)

    # Only keep maxima that fall within our detected particle mask
    maxima_mask = maxima_mask & combined_mask

    # Label the maxima as seeds
    markers = label(maxima_mask)

    # Watershed from those seeds within the combined mask
    split = watershed(original_img, markers, mask=combined_mask)

    return split


def labels_to_particle_dicts(labels, img, min_radius, um_per_pixel):
    props = regionprops(labels, intensity_image=img)
    particle_dicts = []
    for p in props:
        coords = [tuple(c) for c in p.coords.tolist()]
        particle_dicts.append(
            {
                "coords": coords,
                "centroid": (
                    p.centroid[1] * um_per_pixel,
                    p.centroid[0] * um_per_pixel,
                ),
                "effective_diameter": p.equivalent_diameter_area * um_per_pixel,
                "major_axis": p.axis_major_length * um_per_pixel,
                "minor_axis": p.axis_minor_length * um_per_pixel,
                "orientation": p.orientation,
                "pixel_count": len(coords),
                "area": p.area * (um_per_pixel**2),
                "outline_coords": None,
                "circumference": None,
                "corrected_diameter": None,
                "corrected_area": None,
            }
        )

    return [
        p for p in particle_dicts if np.sqrt(p["pixel_count"] / np.pi) >= min_radius
    ]


